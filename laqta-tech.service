[Unit]
Description=laqta.tech Node.js static server
After=network.target

[Service]
Type=simple
User=badr
WorkingDirectory=/home/badr/laqta.tech
ExecStart=/usr/bin/node server.js
Restart=on-failure
RestartSec=5
Environment=PORT=8080
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
